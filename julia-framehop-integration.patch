@@ -294,6 +306,10 @@ JL_DLLEXPORT jl_value_t *jl_backtrace_from_here(int returnsp, int skip)
             skip = 0;
             offset += size_incr;
         }
+        // Release the cursor's pooled slot as soon as stepping is done, before the

@@ -209,6 +209,18 @@ RT_LIBS := $(call whole_archive,$(LIBUV)) $(call whole_archive,$(LIBUTF8PROC)) $
 # NB: CG needs uv_mutex_* symbols, but we expect to export them from libjulia-internal
 CG_LIBS := $(LIBUNWIND) $(CG_LLVMLINK) $(OSLIBS) $(LIBTRACYCLIENT) $(LIBITTAPI)
 
+# Opt-in framehop-backed unwinder (test integration): build with
+#   make JULIA_FRAMEHOP=/abs/path/to/framehopunwind
+# which enables JL_USE_FRAMEHOP for the backtrace path and links libframehopunwind.
+ifdef JULIA_FRAMEHOP
+JCPPFLAGS += -DJL_ENABLE_FRAMEHOP -I$(JULIA_FRAMEHOP)/include
+# debuginfo.cpp (register_eh_frames) is in libjulia-codegen (CG_LIBS); the unwind cursor
+# code (stackwalk.c etc.) is in libjulia-internal (RT_LIBS). Both call into framehop.
+FRAMEHOP_LDLIBS := -L$(JULIA_FRAMEHOP)/target/release -lframehopunwind -Wl,-rpath,$(JULIA_FRAMEHOP)/target/release
+RT_LIBS += $(FRAMEHOP_LDLIBS)
+CG_LIBS += $(FRAMEHOP_LDLIBS)
+endif
+
 ifeq ($(USEGCC),1)
 ifeq ($(USE_RT_STATIC_LIBGCC),1)
 RT_LIBS += -static-libgcc
